# Example environment variables for TravelGetaway backend and database
# Copy this file to .env and fill in real values for local development.
# Do NOT commit your actual .env file with secrets.

POSTGRES_DB=your_db_name
POSTGRES_USER=your_db_user
POSTGRES_PASSWORD=your_db_password
DATABASE_URL=postgres://your_db_user:your_db_password@localhost:5432/your_db_name?sslmode=disable
MIGRATIONS_PATH=file://./db/migrations
PORT=8080
JWT_SECRET=your_jwt_secret_here